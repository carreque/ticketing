        <!-- ==================== EDGES ==================== -->
        <!-- Client <-> API GW -->
        <mxCell id="e1" parent="1" edge="1" source="client" target="apigw" value="Create / Read Ticket (Bearer JWT)  ·  201 / 200 JSON" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=classic;startFill=1;endArrow=classic;endFill=1;fontSize=11;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
