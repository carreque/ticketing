        <!-- Support mailbox -->
        <mxCell id="mailbox" parent="1" value="Support team (email)" vertex="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3D;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.user;">
          <mxGeometry x="900" y="152" width="44" height="44" as="geometry" />
